# CCS / MSP430 build outputs
# Debug/ 下全部由 CCS 自动生成的构建脚本/产物,随时可由 gmake 重建,不入库
Debug/
*.obj
*.out
*.map
*.d
*.d_raw
*_linkInfo.xml

# Local debug launch history and editor caches
.launches/
Debug/.clangd/
.vscode/msp430_intellisense.h

# Docs and helper scripts (local-only)
docs/
tools/

# Misc temporary files
*.tmp
*.bak
*.log

# Local SD text payloads
sdcard/TEXT/BOOK.TXT
sdcard/TEXT/BOOK_SOURCE.TXT
